.menu-card {
  overflow: hidden;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(190, 242, 100, 0.28);
  border-radius: 34rpx;
  box-shadow: 0 18rpx 44rpx rgba(23, 33, 27, 0.08);
}

.cover {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 260rpx;
  color: rgba(23, 33, 27, 0.46);
  font-size: 30rpx;
  letter-spacing: 4rpx;
}

.empty-cover {
  background:
    linear-gradient(135deg, rgba(220, 252, 231, 0.88), rgba(254, 249, 195, 0.92)),
    radial-gradient(circle at 22% 20%, rgba(190, 242, 100, 0.38), transparent 34%);
}

.body {
  padding: 28rpx;
}

.title {
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  min-height: 34rpx;
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.4;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.tag {
  padding: 8rpx 16rpx;
  color: #48604d;
  font-size: 22rpx;
  background: rgba(220, 252, 231, 0.78);
  border-radius: 999rpx;
}
