.menu-card {
  display: flex;
  gap: 20rpx;
  overflow: hidden;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-light);
}

.cover {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 176rpx;
  width: 176rpx;
  height: 176rpx;
  color: rgba(45, 37, 32, 0.42);
  font-size: 24rpx;
  letter-spacing: 4rpx;
  border-radius: 22rpx;
}

.empty-cover {
  background: linear-gradient(135deg, #f1d8c9, #fff8f5);
}

.body {
  flex: 1;
  min-width: 0;
  padding: 4rpx 4rpx 2rpx 0;
}

.meta-row,
.footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.type,
.favorite {
  font-size: 21rpx;
  font-weight: 800;
}

.type {
  color: var(--color-primary);
}

.favorite {
  color: var(--color-danger);
}

.title {
  overflow: hidden;
  margin-top: 10rpx;
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.subtitle {
  overflow: hidden;
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.4;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  max-height: 44rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.tag {
  padding: 7rpx 14rpx;
  color: var(--color-primary);
  font-size: 21rpx;
  background: #f8eee8;
  border-radius: 999rpx;
}

.footer {
  margin-top: 18rpx;
  color: var(--color-muted);
  font-size: 22rpx;
}
