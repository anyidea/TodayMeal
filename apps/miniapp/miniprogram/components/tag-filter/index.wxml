<view class="filter">
  <view wx:if="{{title}}" class="filter-title">{{title}}</view>
  <scroll-view class="scroll" scroll-x enable-flex>
    <view class="options">
      <button
        wx:for="{{options}}"
        wx:key="value"
        class="chip {{active === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="handleChange"
      >
        {{item.label}}
      </button>
    </view>
  </scroll-view>
</view>
