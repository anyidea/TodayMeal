.filter {
  margin-top: 28rpx;
}

.filter-title {
  margin-bottom: 14rpx;
  color: var(--color-muted);
  font-size: 23rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.scroll {
  width: 100%;
  white-space: nowrap;
}

.options {
  display: flex;
  gap: 14rpx;
}

.chip {
  flex: 0 0 auto;
  min-width: 0;
  margin: 0;
  padding: 14rpx 24rpx;
  color: var(--color-muted);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  background: #fff8f5;
  border: 1rpx solid var(--color-line);
  border-radius: 999rpx;
}

.chip::after {
  border: 0;
}

.chip.active {
  color: #ffffff;
  font-weight: 900;
  background: var(--color-primary);
  border-color: var(--color-primary);
  box-shadow: 0 10rpx 26rpx rgba(183, 137, 92, 0.22);
}
