.filter {
  margin-top: 28rpx;
}

.filter-title {
  margin-bottom: 14rpx;
  color: #526456;
  font-size: 23rpx;
  letter-spacing: 3rpx;
}

.scroll {
  width: 100%;
  white-space: nowrap;
}

.options {
  display: flex;
  gap: 14rpx;
}

.chip {
  flex: 0 0 auto;
  min-width: 0;
  margin: 0;
  padding: 14rpx 24rpx;
  color: #526456;
  font-size: 25rpx;
  line-height: 1.2;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(122, 138, 125, 0.18);
  border-radius: 999rpx;
}

.chip::after {
  border: 0;
}

.chip.active {
  color: #17211b;
  font-weight: 700;
  background: linear-gradient(135deg, #bef264, #fef08a);
  border-color: rgba(190, 242, 100, 0.62);
  box-shadow: 0 12rpx 28rpx rgba(190, 242, 100, 0.22);
}
