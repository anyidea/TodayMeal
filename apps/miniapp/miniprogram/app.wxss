page {
  min-height: 100vh;
  background: #fff8f5;
  color: #2d2520;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-weight: 400;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  display: inline-block;
  width: auto;
  min-width: 0;
  padding: 0;
  margin: 0;
  font-size: inherit;
  line-height: 1;
  color: inherit;
  border: 0;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 88rpx 32rpx 160rpx;
  background:
    radial-gradient(circle at 10% 4%, rgba(245, 234, 226, 0.92), transparent 260rpx),
    linear-gradient(180deg, #fffaf7 0%, #fff8f5 42%, #fff 100%);
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
}

.brand-title {
  font-family: "Times New Roman", Georgia, serif;
  font-size: 38rpx;
  font-weight: 600;
  letter-spacing: 0.2rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
}

.muted {
  color: #8c7f76;
}

.tiny {
  color: #c5beb8;
  font-size: 22rpx;
}

.card {
  border: 1rpx solid rgba(239, 231, 225, 0.9);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 8rpx 40rpx rgba(45, 37, 32, 0.08);
}

.soft-card {
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 24rpx rgba(45, 37, 32, 0.06);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 24rpx;
  background: #b7895c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border: 1rpx solid #efe7e1;
  border-radius: 24rpx;
  background: #fff;
  color: #b7895c;
  font-size: 26rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 88rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 32rpx;
  background: #fff8f5;
  color: #8c7f76;
  font-size: 24rpx;
}

.chip.active {
  background: #f5eae2;
  color: #b7895c;
  font-weight: 600;
}

.nav-bar {
  position: fixed;
  right: 24rpx;
  bottom: 24rpx;
  left: 24rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 108rpx;
  padding: 0 8rpx;
  border: 1rpx solid rgba(239, 231, 225, 0.92);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 44rpx rgba(45, 37, 32, 0.1);
}

.nav-item {
  display: flex;
  flex: 1;
  align-items: center;
  flex-direction: column;
  gap: 7rpx;
  color: #8c7f76;
  font-size: 20rpx;
  font-weight: 400;
}

.tm-icon {
  display: inline-block;
  flex: 0 0 auto;
  vertical-align: middle;
}

.icon-inline {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.nav-item.active {
  color: #b7895c;
  font-weight: 500;
}

.nav-random {
  position: relative;
  top: -28rpx;
  display: flex;
  flex: 0 0 112rpx;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  gap: 4rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #b7895c;
  color: #fff;
  box-shadow: 0 12rpx 30rpx rgba(183, 137, 92, 0.34);
}

.nav-random text:last-child {
  display: block;
  color: #fff;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1;
}

.nav-random .tm-icon {
  color: #fff;
}

.food-image {
  width: 100%;
  height: 100%;
  background: #f5eae2;
}
