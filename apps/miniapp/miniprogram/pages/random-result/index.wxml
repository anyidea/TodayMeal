<view class="page random-page">
  <view class="title-block">
    <view class="eyebrow">RANDOM RITUAL</view>
    <view class="headline">今天就吃它</view>
    <view class="subline">把选择交给 Today Meal，保留一点好玩的仪式感。</view>
  </view>

  <block wx:if="{{recommendation}}">
    <view class="result-card card" bindtap="goDetail">
      <image wx:if="{{recommendation.item.coverImageUrl}}" class="result-image" src="{{recommendation.item.coverImageUrl}}" mode="aspectFill" />
      <view wx:else class="result-image empty-cover">Today Meal</view>
      <view class="result-body">
        <view class="result-kicker">命中推荐</view>
        <view class="result-title">{{recommendation.item.title}}</view>
        <view class="result-desc">{{recommendation.reason}}</view>
        <view class="tag-row">
          <text wx:for="{{recommendation.item.tags}}" wx:key="name" class="tag">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="action-row">
      <button class="secondary" bindtap="toggleFavorite">{{recommendation.item.isFavorite ? '取消收藏' : '收藏'}}</button>
      <button class="primary {{drawing ? 'drawing' : ''}}" bindtap="draw" loading="{{drawing}}">再来一次</button>
    </view>
    <button class="eat-button" bindtap="markEaten">就吃这个，记一餐</button>

    <view class="pair-card card">
      <view class="section-title">适合搭配</view>
      <view class="pair-list">
        <view wx:for="{{pairings}}" wx:key="*this" class="pair-item">{{item}}</view>
      </view>
    </view>
  </block>

  <view wx:else class="empty card">
    <view class="empty-title">正在翻今天的菜单</view>
    <view class="empty-text">如果一直没有结果，先去添加几道菜或外卖收藏。</view>
    <button class="primary" bindtap="draw" loading="{{drawing}}">重新抽选</button>
  </view>
</view>
