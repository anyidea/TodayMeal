<view class="page detail-page">
  <block wx:if="{{item}}">
    <view class="cover-wrap">
      <image wx:if="{{item.coverImageUrl}}" class="cover" src="{{item.coverImageUrl}}" mode="aspectFill" />
      <view wx:else class="cover empty-cover">Today Meal</view>
    </view>

    <view class="card content">
      <view class="meta-row">
        <text class="type-pill">{{typeLabel}}</text>
        <text class="meal-period">{{mealPeriodText}}</text>
      </view>
      <view class="title">{{item.title}}</view>
      <view wx:if="{{item.subtitle}}" class="subtitle">{{item.subtitle}}</view>
      <view wx:if="{{item.description}}" class="description">{{item.description}}</view>

      <view class="tags">
        <text wx:for="{{item.tags}}" wx:key="name" class="tag">{{item.name}}</text>
      </view>

      <view wx:if="{{item.type === 'recipe'}}" class="section">
        <view class="section-title">做法笔记</view>
        <view class="info-row">
          <text>用时 {{item.cookTimeMinutes || '待补'}} 分钟</text>
          <text>难度 {{item.difficulty || '随心'}}</text>
        </view>
        <view class="sub-title">食材</view>
        <view wx:for="{{item.ingredients}}" wx:key="*this" class="bullet">· {{item}}</view>
        <view class="sub-title">步骤</view>
        <view wx:for="{{item.steps}}" wx:key="*this" class="step">{{index + 1}}. {{item}}</view>
      </view>

      <view wx:if="{{item.type === 'takeout'}}" class="section">
        <view class="section-title">外卖信息</view>
        <view class="field">餐厅：{{item.restaurantName || '还没写餐厅名'}}</view>
        <view class="field">平台：{{item.platform || '自由选择'}}</view>
        <view class="field">价位：{{item.priceRange || '看心情'}}</view>
        <view wx:if="{{item.deliveryNotes}}" class="field">备注：{{item.deliveryNotes}}</view>
        <button class="link-button" bindtap="copyExternalLink">复制点单链接</button>
      </view>

      <view wx:if="{{item.type === 'inspiration'}}" class="section">
        <view class="section-title">灵感来源</view>
        <view class="field">来源：{{item.sourceName || '偶然想到'}}</view>
        <view wx:if="{{item.notes}}" class="notes">{{item.notes}}</view>
        <button wx:if="{{item.sourceUrl}}" class="link-button" bindtap="copyExternalLink">复制来源链接</button>
      </view>
    </view>

    <view class="actions">
      <button class="action secondary" bindtap="toggleFavorite">{{item.isFavorite ? '取消心动' : '加入心动'}}</button>
      <button class="action primary" bindtap="markEaten">今天吃过</button>
      <button class="action quiet" bindtap="editItem">编辑</button>
    </view>
  </block>
</view>
