.detail-page {
  padding-bottom: 148rpx;
  background:
    radial-gradient(circle at 50% -10%, rgba(254, 240, 138, 0.52), transparent 40%),
    var(--color-bg);
}

.cover-wrap {
  overflow: hidden;
  border-radius: 42rpx;
  box-shadow: 0 20rpx 58rpx rgba(23, 33, 27, 0.1);
}

.cover {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 430rpx;
  color: rgba(23, 33, 27, 0.44);
  font-size: 34rpx;
  letter-spacing: 5rpx;
}

.empty-cover {
  background:
    linear-gradient(135deg, rgba(220, 252, 231, 0.9), rgba(254, 249, 195, 0.94)),
    radial-gradient(circle at 20% 24%, rgba(190, 242, 100, 0.48), transparent 34%);
}

.content {
  margin-top: -48rpx;
  padding: 38rpx;
  position: relative;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.type-pill {
  padding: 10rpx 18rpx;
  color: #48604d;
  font-size: 23rpx;
  font-weight: 700;
  background: rgba(220, 252, 231, 0.84);
  border-radius: 999rpx;
}

.meal-period {
  color: var(--color-muted);
  font-size: 24rpx;
}

.title {
  margin-top: 26rpx;
  color: var(--color-text);
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.14;
}

.subtitle,
.description,
.field,
.notes,
.bullet,
.step,
.info-row {
  color: var(--color-muted);
  font-size: 27rpx;
  line-height: 1.65;
}

.subtitle {
  margin-top: 12rpx;
}

.description {
  margin-top: 20rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 26rpx;
}

.tag {
  padding: 8rpx 16rpx;
  color: #526456;
  font-size: 22rpx;
  background: rgba(254, 249, 195, 0.78);
  border-radius: 999rpx;
}

.section {
  margin-top: 38rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(122, 138, 125, 0.16);
}

.section-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 800;
}

.sub-title {
  margin-top: 26rpx;
  color: #526456;
  font-size: 25rpx;
  font-weight: 800;
}

.info-row {
  display: flex;
  gap: 24rpx;
  margin-top: 14rpx;
}

.link-button {
  margin: 26rpx 0 0;
  padding: 18rpx 26rpx;
  color: #17211b;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  background: linear-gradient(135deg, #bef264, #fef08a);
  border-radius: 999rpx;
}

.actions {
  position: fixed;
  right: 32rpx;
  bottom: 28rpx;
  left: 32rpx;
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 34rpx;
  box-shadow: 0 18rpx 50rpx rgba(23, 33, 27, 0.12);
}

.action {
  flex: 1;
  margin: 0;
  padding: 18rpx 10rpx;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  border-radius: 999rpx;
}

.action::after,
.link-button::after {
  border: 0;
}

.primary {
  color: #17211b;
  background: #bef264;
}

.secondary {
  color: #48604d;
  background: #dcfce7;
}

.quiet {
  color: var(--color-muted);
  background: #f8faf7;
}
