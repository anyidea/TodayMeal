.detail-page {
  padding-bottom: 148rpx;
  background:
    linear-gradient(180deg, #fff8f5 0%, #f5eae2 440rpx, #fff8f5 100%),
    var(--color-bg);
}

.cover-wrap {
  overflow: hidden;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-medium);
}

.cover {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 430rpx;
  color: rgba(45, 37, 32, 0.44);
  font-size: 34rpx;
  letter-spacing: 5rpx;
}

.empty-cover {
  background:
    linear-gradient(135deg, #f1d8c9, #fff8f5),
    radial-gradient(circle at 20% 24%, rgba(183, 137, 92, 0.16), transparent 34%);
}

.content {
  margin-top: -48rpx;
  padding: 38rpx;
  position: relative;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.type-pill {
  padding: 10rpx 18rpx;
  color: var(--color-primary);
  font-size: 23rpx;
  font-weight: 700;
  background: #f8eee8;
  border-radius: 999rpx;
}

.meal-period {
  color: var(--color-muted);
  font-size: 24rpx;
}

.title {
  margin-top: 26rpx;
  color: var(--color-text);
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.14;
}

.subtitle,
.description,
.field,
.notes,
.bullet,
.step,
.info-row {
  color: var(--color-muted);
  font-size: 27rpx;
  line-height: 1.65;
}

.subtitle {
  margin-top: 12rpx;
}

.description {
  margin-top: 20rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 26rpx;
}

.tag {
  padding: 8rpx 16rpx;
  color: var(--color-primary);
  font-size: 22rpx;
  background: #f8eee8;
  border-radius: 999rpx;
}

.section {
  margin-top: 38rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid var(--color-line);
}

.section-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 800;
}

.sub-title {
  margin-top: 26rpx;
  color: var(--color-primary);
  font-size: 25rpx;
  font-weight: 800;
}

.info-row {
  display: flex;
  gap: 24rpx;
  margin-top: 14rpx;
}

.link-button {
  margin: 26rpx 0 0;
  padding: 18rpx 26rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  background: var(--color-primary);
  border-radius: 999rpx;
}

.actions {
  position: fixed;
  right: 32rpx;
  bottom: 28rpx;
  left: 32rpx;
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 34rpx;
  border: 1rpx solid var(--color-line);
  box-shadow: var(--shadow-medium);
}

.action {
  flex: 1;
  margin: 0;
  padding: 18rpx 10rpx;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  border-radius: 999rpx;
}

.action::after,
.link-button::after {
  border: 0;
}

.primary {
  color: #ffffff;
  background: var(--color-primary);
}

.secondary {
  color: var(--color-primary);
  background: #f8eee8;
}

.quiet {
  color: var(--color-muted);
  background: #fff8f5;
}
