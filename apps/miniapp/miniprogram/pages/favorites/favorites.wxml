<view class="page favorites-page">
  <view class="topbar">
    <text class="page-title">外卖收藏</text>
    <view class="tools">
      <view class="tool-btn">
        <t-icon class="tm-icon" name="search" size="36rpx" color="#2D2520" />
      </view>
      <view class="tool-btn" bindtap="goAddTakeout">
        <t-icon class="tm-icon" name="add" size="36rpx" color="#2D2520" />
      </view>
    </view>
  </view>

  <scroll-view class="tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tab-row">
      <block wx:for="{{tabs}}" wx:key="*this">
        <view class="tab {{activeTab === index ? 'active' : ''}}" data-index="{{index}}" bindtap="chooseTab">{{item}}</view>
      </block>
    </view>
  </scroll-view>

  <view class="store-list">
    <block wx:for="{{stores}}" wx:key="name">
      <view class="store-item soft-card">
        <view class="store-cover-wrap">
          <image class="store-img" src="{{item.image}}" mode="aspectFill"></image>
          <view class="corner-tag">
            <text>{{item.tag}}</text>
          </view>
        </view>
        <view class="store-info">
          <view class="store-top">
            <text class="store-name">{{item.name}}</text>
            <view class="more-btn">
              <t-icon class="tm-icon" name="more" size="32rpx" color="#C5BEB8" />
            </view>
          </view>
          <text class="store-desc">{{item.desc}}</text>
          <view class="store-bottom">
            <text class="price">{{item.price}}</text>
            <button wx:if="{{item.externalUrl}}" class="order-link" data-url="{{item.externalUrl}}" catchtap="openExternalUrl">打开</button>
            <view wx:else class="meta-tag">
              <t-icon class="tm-icon icon-inline" name="heart" size="24rpx" color="#FF6B6B" />
              <text>{{item.likes}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="nav-bar">
    <view class="nav-item" bindtap="goHome">
      <t-icon class="tm-icon" name="home" size="36rpx" color="#8C7F76" />
      <text>首页</text>
    </view>
    <view class="nav-item" bindtap="goRecipes">
      <t-icon class="tm-icon" name="book-open" size="36rpx" color="#8C7F76" />
      <text>菜谱</text>
    </view>
    <view class="nav-item nav-random" bindtap="goRandom">
      <t-icon class="tm-icon" name="refresh" size="44rpx" color="#FFFFFF" />
      <text>随机</text>
    </view>
    <view class="nav-item active">
      <t-icon class="tm-icon" name="heart" size="36rpx" color="#B7895C" />
      <text>收藏</text>
    </view>
    <view class="nav-item" bindtap="goProfile">
      <t-icon class="tm-icon" name="user" size="36rpx" color="#8C7F76" />
      <text>我的</text>
    </view>
  </view>
</view>
