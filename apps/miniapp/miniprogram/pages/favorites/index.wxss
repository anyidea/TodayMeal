.favorites-page {
  background:
    linear-gradient(180deg, #fff8f5 0%, #f5eae2 400rpx, #fff8f5 100%),
    var(--color-bg);
}

.top {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  padding: 12rpx 4rpx 28rpx;
}

.eyebrow {
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.headline {
  margin-top: 14rpx;
  color: var(--color-text);
  font-size: 50rpx;
  font-weight: 900;
}

.subline,
.empty-text {
  margin-top: 12rpx;
  color: var(--color-muted);
  font-size: 25rpx;
  line-height: 1.5;
}

.add-btn,
.empty-action {
  margin: 0;
  padding: 18rpx 26rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.2;
  background: var(--color-primary);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 28rpx rgba(183, 137, 92, 0.22);
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  padding: 2rpx 4rpx 22rpx;
}

.chip {
  margin: 0;
  padding: 16rpx 26rpx;
  color: var(--color-muted);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  background: #ffffff;
  border-radius: 999rpx;
}

.chip.active {
  color: #ffffff;
  background: var(--color-primary);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty {
  margin-top: 24rpx;
  padding: 40rpx;
  text-align: center;
}

.empty-title {
  color: var(--color-text);
  font-size: 34rpx;
  font-weight: 900;
}

.empty-action {
  display: inline-flex;
  margin-top: 28rpx;
}
