.favorites-page {
  padding-bottom: 170rpx;
}

.tools {
  display: flex;
  align-items: center;
  gap: 24rpx;
  color: #2d2520;
}

.tools .tm-icon {
  width: 34rpx;
  height: 34rpx;
}

.tools .icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
}

.add-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 104rpx;
  margin-top: 24rpx;
  padding: 22rpx 26rpx;
  border: 1rpx solid #efe7e1;
  border-radius: 28rpx;
  background: #fff;
  text-align: left;
  box-shadow: 0 4rpx 24rpx rgba(45, 37, 32, 0.06);
}

.add-banner text {
  display: block;
}

.add-banner text:first-child {
  color: #2d2520;
  font-size: 28rpx;
  font-weight: 600;
}

.add-banner text:last-child {
  margin-top: 8rpx;
  color: #8c7f76;
  font-size: 22rpx;
}

.tabs {
  width: calc(100% + 64rpx);
  margin: 26rpx -32rpx 0;
  padding-left: 32rpx;
  white-space: nowrap;
}

.tab-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 32rpx;
  white-space: nowrap;
}

.tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 72rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  background: transparent;
  color: #8c7f76;
  font-size: 24rpx;
  line-height: 56rpx;
  white-space: nowrap;
}

.tab.active {
  background: #b7895c;
  color: #fff;
  font-weight: 600;
}

.store-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 26rpx;
}

.store-item {
  display: flex;
  min-height: 176rpx;
  padding: 16rpx;
}

.store-cover-wrap {
  position: relative;
  flex: 0 0 152rpx;
  width: 152rpx;
  height: 144rpx;
}

.store-img {
  width: 152rpx;
  height: 144rpx;
  border-radius: 24rpx;
}

.corner-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 12rpx;
  background: rgba(45, 37, 32, 0.78);
  color: #fff;
  font-size: 20rpx;
}

.store-info {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0 4rpx 22rpx;
}

.store-top,
.store-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.store-name {
  max-width: 330rpx;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.more,
.store-desc,
.store-bottom {
  color: #8c7f76;
  font-size: 22rpx;
}

.more {
  width: 30rpx;
  height: 30rpx;
  color: #c5beb8;
}

.store-bottom {
  color: #c5beb8;
}

.store-bottom view {
  display: flex;
  align-items: center;
}

.store-bottom .icon-inline {
  width: 20rpx;
  height: 20rpx;
  margin-right: 6rpx;
}

.price {
  color: #2d2520;
  font-size: 26rpx;
  font-weight: 800;
}
