.favorites-page {
  padding-top: 104rpx;
  padding-bottom: 180rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-right: 190rpx;
}

.page-title {
  color: #2d2520;
  font-size: 48rpx;
  font-weight: 700;
}

.tools {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tool-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(45, 37, 32, 0.04);
  transition: all 0.2s ease;
}

.tool-btn:active {
  transform: scale(0.95);
  background: #f9f6f4;
}

.tabs {
  width: calc(100% + 64rpx);
  margin: 40rpx -32rpx 0;
  padding-left: 32rpx;
  white-space: nowrap;
}

.tab-row {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 32rpx;
  white-space: nowrap;
}

.tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 80rpx;
  height: 64rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  color: #8c7f76;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
  box-shadow: 0 4rpx 16rpx rgba(45, 37, 32, 0.02);
  transition: all 0.3s ease;
}

.tab.active {
  background: #b7895c;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(183, 137, 92, 0.24);
}

.store-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 32rpx;
}

.store-item {
  display: flex;
  min-height: 200rpx;
  padding: 24rpx;
  gap: 24rpx;
}

.store-cover-wrap {
  position: relative;
  flex: 0 0 160rpx;
  width: 160rpx;
  height: 160rpx;
}

.store-img {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
}

.store-img-placeholder {
  background:
    radial-gradient(circle at 22% 18%, rgba(255, 255, 255, 0.86), transparent 56rpx),
    linear-gradient(135deg, #fff8f5 0%, #f5eae2 100%);
}

.corner-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: rgba(45, 37, 32, 0.65);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  backdrop-filter: blur(8rpx);
}

.store-info {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
  padding: 8rpx 0;
}

.store-top,
.store-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.store-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #2d2520;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  border-radius: 50%;
}

.more-btn:active {
  background: #fff8f5;
}

.store-desc {
  color: #8c7f76;
  font-size: 24rpx;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: auto;
}

.price {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #2d2520;
  font-family: "DIN", -apple-system, sans-serif;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.store-spacer {
  flex: 1;
  min-width: 0;
}

.meta-tag {
  display: flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #fff8f5;
  color: #8c7f76;
  font-size: 22rpx;
  font-weight: 600;
}

.favorite-tag {
  background: rgba(255, 107, 107, 0.1);
  color: #d85d5d;
}

.meta-tag .icon-inline {
  margin-right: 8rpx;
}

.order-link {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 88rpx;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  background: #f5eae2;
  color: #b7895c;
  font-size: 22rpx;
  font-weight: 600;
}
