.home-page {
  padding-top: 96rpx;
}

.greeting {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 40rpx;
  padding: 0 8rpx;
}

.hello,
.hint {
  display: block;
}

.hello {
  color: #2d2520;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.4;
}

.hint {
  margin-top: 12rpx;
  color: #8c7f76;
  font-size: 26rpx;
  line-height: 1.5;
}

.mascot {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(183, 137, 92, 0.12);
}

.mascot .tm-icon-soup {
  color: #b7895c;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 360rpx;
  margin-top: 48rpx;
  padding: 40rpx;
  border-radius: 48rpx;
  color: #fff;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(135deg, rgba(183, 137, 92, 0.4), transparent),
    url("https://images.unsplash.com/photo-1543353071-10c8ba85a904?auto=format&fit=crop&w=900&q=80");
  background-size: cover;
  background-position: center;
}

.hero-content {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  text-shadow: 0 4rpx 16rpx rgba(45, 37, 32, 0.2);
}

.hero-subtitle {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  text-shadow: 0 4rpx 16rpx rgba(45, 37, 32, 0.2);
}

.hero-button {
  position: relative;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  margin-top: 40rpx;
  padding: 0 32rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #2d2520;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(45, 37, 32, 0.08);
}

.hero-button .icon-inline,
.section-action .icon-inline {
  margin: 0 0 0 8rpx;
}

.dish-bubbles {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  z-index: 2;
  display: flex;
}

.dish-bubble {
  width: 104rpx;
  height: 104rpx;
  margin-left: -20rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-shadow: 0 16rpx 48rpx rgba(45, 37, 32, 0.12);
}

.quick-grid {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.quick-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  min-height: 160rpx;
  padding: 28rpx;
  text-align: left;
}

.quick-card > view {
  min-width: 0;
}

.quick-title,
.quick-subtitle {
  display: block;
}

.quick-title {
  color: #2d2520;
  font-size: 32rpx;
  font-weight: 600;
  white-space: nowrap;
}

.quick-subtitle {
  margin-top: 12rpx;
  color: #c5beb8;
  font-size: 24rpx;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  margin-left: 16rpx;
  border-radius: 20rpx;
  background: #f5eae2;
  color: #b7895c;
}

.quick-icon .tm-icon {
  color: #b7895c;
}

.add-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 24rpx;
}

.add-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 80rpx;
  border: 1rpx solid rgba(239, 231, 225, 0.6);
  border-radius: 24rpx;
  background: #ffffff;
  color: #b7895c;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(45, 37, 32, 0.03);
}

.add-action.primary {
  border: none;
  background: #b7895c;
  color: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(183, 137, 92, 0.2);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 48rpx 0 24rpx;
  padding: 0 8rpx;
}

.section-action {
  display: flex;
  align-items: center;
  color: #b7895c;
  font-size: 26rpx;
}

.inspiration-scroll {
  width: 100%;
  overflow: visible;
}

.dish-row {
  display: flex;
  gap: 24rpx;
  padding-bottom: 24rpx;
}

.dish-row::after {
  display: block;
  flex: 0 0 32rpx;
  content: "";
}

.dish-card {
  flex: 0 0 200rpx;
  overflow: hidden;
  padding-bottom: 24rpx;
}

.dish-cover {
  width: 200rpx;
  height: 160rpx;
  border-radius: 32rpx 32rpx 24rpx 24rpx;
}

.dish-name,
.dish-meta {
  display: block;
  padding: 0 20rpx;
}

.dish-name {
  margin-top: 16rpx;
  color: #2d2520;
  font-size: 28rpx;
  font-weight: 600;
}

.dish-meta {
  margin-top: 10rpx;
  color: #8c7f76;
  font-size: 22rpx;
}
