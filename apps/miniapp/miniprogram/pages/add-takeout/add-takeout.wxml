<view class="page add-takeout-page">
  <view class="topbar">
    <button class="back icon-button" bindtap="back"><t-icon class="tm-icon" name="chevron-left" size="34rpx" color="#2D2520" /></button>
    <text class="page-title">添加外卖</text>
    <view class="capsule-space"></view>
  </view>

  <view class="hero-card card">
    <view class="hero-icon">
      <t-icon name="shop" size="44rpx" color="#B7895C" />
    </view>
    <view>
      <text class="hero-title">收藏常点外卖</text>
      <text class="hero-desc">把想吃的店、套餐和价格记下来，下次不用再纠结。</text>
    </view>
  </view>

  <view class="link-card card">
    <view class="link-head">
      <view>
        <text class="link-title">外卖链接</text>
        <text class="link-desc">支持美团、大众点评短链、淘宝闪购，分享文案也可直接粘贴。</text>
      </view>
      <button class="parse-button" loading="{{isParsing}}" bindtap="parseLink">解析</button>
    </view>
    <input
      class="link-input"
      value="{{form.externalUrl}}"
      placeholder="粘贴外卖分享链接"
      placeholder-class="placeholder"
      bindinput="onInput"
      data-field="externalUrl"
    />
    <view wx:if="{{parseStatus}}" class="parse-status {{parseStatus}}">
      <text>{{parseMessage}}</text>
    </view>
  </view>

  <view class="form-card card">
    <view class="form-row">
      <text class="label">店铺名称</text>
      <input value="{{form.restaurantName}}" data-field="restaurantName" bindinput="onInput" placeholder="例如：太二酸菜鱼" placeholder-class="placeholder" />
    </view>
    <view class="form-row">
      <text class="label">常点菜单</text>
      <input value="{{form.title}}" data-field="title" bindinput="onInput" placeholder="例如：酸菜鱼双人餐" placeholder-class="placeholder" />
    </view>
    <view class="form-row">
      <text class="label">平台</text>
      <input value="{{form.platformLabel}}" data-field="platformLabel" bindinput="onInput" placeholder="美团 / 淘宝闪购" placeholder-class="placeholder" />
    </view>
    <view class="form-row">
      <text class="label">人均价格</text>
      <input value="{{form.priceRange}}" data-field="priceRange" bindinput="onInput" placeholder="例如：¥68" placeholder-class="placeholder" />
    </view>

    <view class="note-block">
      <text class="label">备注（可选）</text>
      <textarea value="{{form.notes}}" data-field="notes" bindinput="onInput" placeholder="比如配送快、分量足、适合加班夜宵～" placeholder-class="placeholder"></textarea>
    </view>
  </view>

  <button class="save-action primary-button" bindtap="save">保存外卖</button>
</view>
