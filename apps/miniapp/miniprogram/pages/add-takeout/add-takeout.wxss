.add-takeout-page {
  padding-bottom: 56rpx;
}

.back,
.save {
  color: #2d2520;
}

.icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
}

.page-title {
  font-size: 32rpx;
  font-weight: 600;
}

.hero-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 32rpx;
  padding: 28rpx;
}

.hero-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 28rpx;
  background: #f5eae2;
}

.hero-title,
.hero-desc {
  display: block;
}

.hero-title {
  color: #2d2520;
  font-size: 30rpx;
  font-weight: 600;
}

.hero-desc {
  margin-top: 8rpx;
  color: #8c7f76;
  font-size: 23rpx;
  line-height: 1.5;
}

.form-card {
  margin-top: 24rpx;
  padding: 10rpx 28rpx 28rpx;
  box-shadow: none;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  border-bottom: 1rpx solid #efe7e1;
}

.label {
  color: #2d2520;
  font-size: 26rpx;
  font-weight: 600;
}

.form-row input {
  flex: 1;
  min-width: 0;
  text-align: right;
  color: #2d2520;
  font-size: 24rpx;
}

.placeholder {
  color: #c5beb8;
}

.note-block {
  padding-top: 26rpx;
}

.note-block textarea {
  width: 100%;
  min-height: 180rpx;
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff8f5;
  color: #2d2520;
  font-size: 24rpx;
}
