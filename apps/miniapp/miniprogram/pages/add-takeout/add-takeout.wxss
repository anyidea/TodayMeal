.add-takeout-page {
  padding-bottom: 88rpx;
}

.add-takeout-page .topbar {
  position: relative;
  justify-content: flex-start;
  padding-right: 190rpx;
}

.back {
  color: #2d2520;
  flex: 0 0 64rpx;
}

.capsule-space {
  flex: 1;
  min-width: 190rpx;
}

.icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
}

.page-title {
  position: absolute;
  left: 50%;
  max-width: 260rpx;
  overflow: hidden;
  color: #2d2520;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  text-overflow: ellipsis;
  transform: translateX(-50%);
  white-space: nowrap;
}

.hero-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 32rpx;
  padding: 28rpx;
}

.hero-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 84rpx;
  border-radius: 28rpx;
  background: #f5eae2;
}

.hero-title,
.hero-desc {
  display: block;
}

.hero-title {
  color: #2d2520;
  font-size: 30rpx;
  font-weight: 600;
}

.hero-desc {
  margin-top: 8rpx;
  color: #8c7f76;
  font-size: 23rpx;
  line-height: 1.5;
}

.link-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.link-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.link-title,
.link-desc {
  display: block;
}

.link-title {
  color: #2d2520;
  font-size: 28rpx;
  font-weight: 600;
}

.link-desc {
  margin-top: 8rpx;
  color: #8c7f76;
  font-size: 23rpx;
  line-height: 1.45;
}

.parse-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 120rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #b7895c;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 32rpx rgba(183, 137, 92, 0.18);
}

.link-input {
  width: 100%;
  height: 80rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #fff8f5;
  color: #2d2520;
  font-size: 24rpx;
}

.parse-status {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  font-size: 23rpx;
  line-height: 1.4;
}

.parse-status.success {
  background: rgba(95, 184, 120, 0.12);
  color: #4a9a61;
}

.parse-status.failed {
  background: rgba(255, 107, 107, 0.1);
  color: #d85d5d;
}

.form-card {
  margin-top: 24rpx;
  padding: 10rpx 28rpx 28rpx;
  box-shadow: none;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  border-bottom: 1rpx solid #efe7e1;
}

.label {
  color: #2d2520;
  font-size: 26rpx;
  font-weight: 600;
}

.form-row input {
  flex: 1;
  min-width: 0;
  padding-left: 24rpx;
  text-align: right;
  color: #2d2520;
  font-size: 24rpx;
}

.placeholder {
  color: #c5beb8;
}

.note-block {
  padding-top: 26rpx;
}

.note-block textarea {
  width: 100%;
  min-height: 180rpx;
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff8f5;
  color: #2d2520;
  font-size: 24rpx;
}

.save-action {
  width: 100%;
  margin-top: 28rpx;
}
