<view class="page group-invite-page">
  <view class="topbar">
    <button class="back icon-button" bindtap="back">
      <t-icon class="tm-icon" name="chevron-left" size="34rpx" color="#2D2520" />
    </button>
    <text class="page-title">邀请饭搭子</text>
    <view class="top-placeholder"></view>
  </view>

  <view wx:if="{{pendingInviteCode}}" class="invite-card card share-join-card">
    <view class="share-badge">
      <t-icon class="tm-icon" name="usergroup" size="34rpx" color="#B7895C" />
    </view>
    <text class="card-title">正在加入饭团</text>
    <text class="card-desc">来自微信好友的邀请，登录后会自动加入饭团，一起维护菜谱和外卖收藏。</text>
    <button class="primary-button" loading="{{isLoading}}" bindtap="joinFromShare">
      {{isLoading ? '加入中' : '立即加入'}}
    </button>
  </view>

  <view wx:else class="invite-card card">
    <text class="card-title">{{currentGroupName || '我的饭团'}}</text>
    <text class="card-desc">直接发给微信好友，对方点开小程序就会加入这个饭团。</text>
    <button
      class="primary-button share-button"
      open-type="share"
      loading="{{isLoading}}"
      disabled="{{!inviteCode || isLoading}}"
    >
      <t-icon class="tm-icon" name="share" size="30rpx" color="#FFFFFF" />
      <text>{{inviteCode ? '微信邀请好友' : '准备邀请中'}}</text>
    </button>
    <view class="share-hint">
      <text>{{inviteCode ? '好友点击分享卡片后会自动加入' : '正在生成一次性邀请链接'}}</text>
    </view>
    <view wx:if="{{inviteCode}}" class="code-box" bindtap="copyInviteCode">
      <text>{{inviteCode}}</text>
      <text class="copy-text">复制备用</text>
    </view>
  </view>

  <view wx:if="{{!pendingInviteCode}}" class="join-card card">
    <text class="card-title">加入别人的饭团</text>
    <text class="card-desc">如果对方只能发给你邀请码，也可以在这里手动加入。</text>
    <view class="join-row">
      <input
        class="join-input"
        value="{{joinCode}}"
        placeholder="输入邀请码"
        placeholder-class="placeholder"
        bindinput="onJoinCodeInput"
      />
      <button class="join-button" loading="{{isLoading}}" bindtap="joinByCode">加入</button>
    </view>
  </view>
</view>
