.profile-page {
  background:
    linear-gradient(180deg, #fff8f5 0%, #f5eae2 420rpx, #fff8f5 100%),
    var(--color-bg);
}

.hero-card,
.invite-card {
  padding: 36rpx;
}

.eyebrow {
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.headline {
  margin-top: 16rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.16;
}

.login-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 34rpx;
}

.status {
  font-size: 30rpx;
  font-weight: 800;
}

.role,
.section-note,
.history-subtitle,
.empty {
  color: var(--color-muted);
  font-size: 25rpx;
  line-height: 1.55;
}

.login-button,
.bind-button {
  margin: 0;
  padding: 18rpx 26rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.2;
  background: var(--color-primary);
  border-radius: 999rpx;
}

.login-button::after,
.bind-button::after {
  border: 0;
}

.stats-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.stat-card {
  flex: 1;
  padding: 30rpx;
}

.stat-number {
  color: var(--color-text);
  font-size: 48rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 6rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.invite-card {
  margin-top: 24rpx;
}

.section-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 800;
}

.invite-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.invite-input {
  flex: 1;
  height: 82rpx;
  padding: 0 24rpx;
  color: var(--color-text);
  font-size: 27rpx;
  background: #fff8f5;
  border: 1rpx solid var(--color-line);
  border-radius: 26rpx;
}

.history-head {
  margin: 40rpx 4rpx 18rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.history-item {
  display: flex;
  gap: 20rpx;
  padding: 18rpx;
}

.history-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  color: rgba(45, 37, 32, 0.45);
  font-size: 22rpx;
  background: linear-gradient(135deg, #f1d8c9, #fff8f5);
  border-radius: 26rpx;
}

.empty-cover {
  letter-spacing: 3rpx;
}

.history-body {
  flex: 1;
  padding-top: 10rpx;
}

.history-title {
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 800;
}

.empty {
  padding: 34rpx;
}
