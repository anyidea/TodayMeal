<view class="page profile-page">
  <view class="topbar">
    <text class="brand-title">Today Meal</text>
    <text class="muted">我的</text>
  </view>

  <view class="profile-card card">
    <view class="profile-row">
      <button
        wx:if="{{user}}"
        class="avatar-button"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
        aria-label="选择微信头像"
      >
        <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar">TM</view>
      </button>
      <view wx:else class="avatar">TM</view>

      <view class="profile-main">
        <text class="name">{{nicknameInput || '今天也要好好吃饭'}}</text>
        <text class="status-text">{{statusLabel}}</text>
      </view>

      <button wx:if="{{!user}}" class="profile-link" bindtap="loginWithWechat">
        微信登录
      </button>

      <button wx:else class="profile-link muted-link" bindtap="logout">
        退出登录
      </button>
    </view>

    <form wx:if="{{user && needsProfileSetup}}" class="profile-setup" bindsubmit="submitProfile">
      <view class="setup-title-row">
        <text class="setup-title">完善微信资料</text>
        <text class="setup-tip">昵称必填，头像可选</text>
      </view>
      <view class="setup-row">
        <input
          class="nickname-input"
          name="nickname"
          type="nickname"
          placeholder="选择微信昵称"
          value="{{nicknameInput}}"
          bindinput="onNicknameInput"
        />
        <button class="profile-link" form-type="submit" loading="{{isSavingProfile}}">
          完成
        </button>
      </view>
    </form>
  </view>

  <view class="stats">
    <view class="stat soft-card">
      <text>{{summary.recipeCount}}</text>
      <text>我的菜谱</text>
    </view>
    <view class="stat soft-card">
      <text>{{summary.takeoutCount}}</text>
      <text>外卖收藏</text>
    </view>
    <view class="stat soft-card">
      <text>{{summary.recentMealCount}}</text>
      <text>本周灵感</text>
    </view>
  </view>

  <view wx:if="{{user}}" class="group-card card">
    <view class="group-head">
      <view>
        <text class="group-eyebrow">我的饭团</text>
        <text class="group-name">{{currentGroupName || '我的饭团'}}</text>
      </view>
      <view class="avatar-stack" bindtap="goGroupMembers">
        <block wx:for="{{groupAvatars}}" wx:key="userId">
          <view class="stack-avatar">
            <image wx:if="{{item.avatarUrl}}" class="stack-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
            <text wx:else>{{item.initial}}</text>
          </view>
        </block>
        <view wx:if="{{extraGroupMemberCount > 0}}" class="stack-avatar stack-extra">
          <text>+{{extraGroupMemberCount}}</text>
        </view>
      </view>
    </view>

    <view class="group-actions">
      <button class="group-action secondary" bindtap="goGroups">切换饭团</button>
      <button class="group-action primary" bindtap="goGroupInvite">邀请饭搭子</button>
    </view>
  </view>

  <view class="nav-bar">
    <view class="nav-item" bindtap="goHome">
      <t-icon class="tm-icon" name="home" size="32rpx" color="#8C7F76" />
      <text>首页</text>
    </view>
    <view class="nav-item" bindtap="goRecipes">
      <t-icon class="tm-icon" name="book-open" size="32rpx" color="#8C7F76" />
      <text>菜谱</text>
    </view>
    <view class="nav-item nav-random" bindtap="goRandom">
      <t-icon class="tm-icon" name="refresh" size="38rpx" color="#FFFFFF" />
      <text>随机</text>
    </view>
    <view class="nav-item" bindtap="goFavorites">
      <t-icon class="tm-icon" name="heart" size="32rpx" color="#8C7F76" />
      <text>收藏</text>
    </view>
    <view class="nav-item active">
      <t-icon class="tm-icon" name="user" size="32rpx" color="#B7895C" />
      <text>我的</text>
    </view>
  </view>
</view>
