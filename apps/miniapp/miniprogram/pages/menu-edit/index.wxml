<view class="page edit-page">
  <view class="intro card">
    <view class="eyebrow">NEW ENTRY</view>
    <view class="headline">{{id ? '修改这张菜单卡片' : '记下一道她可能会喜欢的'}}</view>
    <view class="type-row">
      <button class="type-chip {{type === 'recipe' ? 'active' : ''}}" data-type="recipe" bindtap="setType">菜谱</button>
      <button class="type-chip {{type === 'takeout' ? 'active' : ''}}" data-type="takeout" bindtap="setType">外卖</button>
      <button class="type-chip {{type === 'inspiration' ? 'active' : ''}}" data-type="inspiration" bindtap="setType">灵感</button>
    </view>
  </view>

  <view class="card form-card">
    <view class="field-label">名字</view>
    <input class="input" placeholder="例如：番茄牛腩饭" value="{{title}}" data-field="title" bindinput="handleInput" />

    <view class="field-label">一句话小标题</view>
    <input class="input" placeholder="暖暖的、适合下班后吃" value="{{subtitle}}" data-field="subtitle" bindinput="handleInput" />

    <view class="field-label">封面</view>
    <view class="cover-picker" bindtap="chooseImage">
      <image wx:if="{{coverImageUrl}}" class="cover-preview" src="{{coverImageUrl}}" mode="aspectFill" />
      <view wx:else class="cover-empty">点这里放一张图</view>
    </view>

    <view class="field-label">适合什么时候吃</view>
    <view class="meal-row">
      <button class="meal-chip {{breakfastActive ? 'active' : ''}}" data-period="breakfast" bindtap="toggleMealPeriod">早餐</button>
      <button class="meal-chip {{lunchActive ? 'active' : ''}}" data-period="lunch" bindtap="toggleMealPeriod">午餐</button>
      <button class="meal-chip {{dinnerActive ? 'active' : ''}}" data-period="dinner" bindtap="toggleMealPeriod">晚餐</button>
      <button class="meal-chip {{lateNightActive ? 'active' : ''}}" data-period="lateNight" bindtap="toggleMealPeriod">夜宵</button>
    </view>

    <view class="field-label">标签</view>
    <input class="input" placeholder="清淡，热乎，周末" value="{{tagText}}" data-field="tagText" bindinput="handleInput" />

    <view class="field-label">描述</view>
    <textarea class="textarea" placeholder="写一点为什么想把它收进来" value="{{description}}" data-field="description" bindinput="handleInput" />
  </view>

  <view wx:if="{{type === 'takeout'}}" class="card form-card">
    <view class="section-title">外卖链接</view>
    <input class="input" placeholder="粘贴店铺或菜品链接" value="{{externalUrl}}" data-field="externalUrl" bindinput="handleInput" />
    <button class="soft-button" bindtap="previewLink">自动识别</button>
    <view wx:if="{{previewMessage}}" class="hint">{{previewMessage}}</view>

    <view class="field-label">餐厅</view>
    <input class="input" placeholder="店名" value="{{restaurantName}}" data-field="restaurantName" bindinput="handleInput" />
    <view class="field-label">平台</view>
    <input class="input" placeholder="美团 / 淘宝闪购 / 小程序" value="{{platform}}" data-field="platform" bindinput="handleInput" />
    <view class="field-label">价位</view>
    <input class="input" placeholder="约 40-60 元" value="{{priceRange}}" data-field="priceRange" bindinput="handleInput" />
    <view class="field-label">点单备注</view>
    <textarea class="textarea" placeholder="少辣、加蛋、不要香菜..." value="{{deliveryNotes}}" data-field="deliveryNotes" bindinput="handleInput" />
  </view>

  <view wx:if="{{type === 'recipe'}}" class="card form-card">
    <view class="section-title">菜谱细节</view>
    <view class="field-label">食材（每行一个）</view>
    <textarea class="textarea" placeholder="牛腩&#10;番茄&#10;土豆" value="{{ingredientsText}}" data-field="ingredientsText" bindinput="handleInput" />
    <view class="field-label">步骤（每行一步）</view>
    <textarea class="textarea tall" placeholder="焯水去腥&#10;小火炖到软烂" value="{{stepsText}}" data-field="stepsText" bindinput="handleInput" />
    <view class="split-row">
      <view class="split-field">
        <view class="field-label">用时</view>
        <input class="input" type="number" placeholder="45" value="{{cookTimeMinutes}}" data-field="cookTimeMinutes" bindinput="handleInput" />
      </view>
      <view class="split-field">
        <view class="field-label">难度</view>
        <input class="input" placeholder="简单 / 需要耐心" value="{{difficulty}}" data-field="difficulty" bindinput="handleInput" />
      </view>
    </view>
  </view>

  <view wx:if="{{type === 'inspiration'}}" class="card form-card">
    <view class="section-title">灵感备注</view>
    <view class="field-label">来源</view>
    <input class="input" placeholder="朋友推荐 / 小红书 / 突然想到" value="{{sourceName}}" data-field="sourceName" bindinput="handleInput" />
    <view class="field-label">来源链接</view>
    <input class="input" placeholder="可选" value="{{sourceUrl}}" data-field="sourceUrl" bindinput="handleInput" />
    <view class="field-label">笔记</view>
    <textarea class="textarea tall" placeholder="这条灵感适合怎么变成一顿饭？" value="{{notes}}" data-field="notes" bindinput="handleInput" />
  </view>

  <button class="save-button" bindtap="submit" loading="{{submitting}}">保存菜单</button>
</view>
