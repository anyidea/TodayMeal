.edit-page {
  padding-bottom: 48rpx;
  background:
    linear-gradient(180deg, #fff8f5 0%, #f5eae2 460rpx, #fff8f5 100%),
    var(--color-bg);
}

.intro,
.form-card {
  padding: 34rpx;
}

.form-card {
  margin-top: 28rpx;
}

.eyebrow {
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.headline {
  margin-top: 14rpx;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.18;
}

.type-row,
.meal-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.type-chip,
.meal-chip {
  margin: 0;
  padding: 15rpx 24rpx;
  color: var(--color-muted);
  font-size: 25rpx;
  line-height: 1.2;
  background: #fff8f5;
  border: 1rpx solid var(--color-line);
  border-radius: 999rpx;
}

.type-chip.active,
.meal-chip.active {
  color: #ffffff;
  font-weight: 800;
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.type-chip::after,
.meal-chip::after,
.soft-button::after,
.save-button::after {
  border: 0;
}

.field-label {
  margin: 28rpx 0 12rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  font-weight: 800;
}

.section-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 800;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  color: var(--color-text);
  font-size: 27rpx;
  background: #fff8f5;
  border: 1rpx solid var(--color-line);
  border-radius: 26rpx;
}

.input {
  height: 84rpx;
}

.textarea {
  min-height: 170rpx;
}

.textarea.tall {
  min-height: 240rpx;
}

.cover-picker {
  overflow: hidden;
  height: 310rpx;
  background: linear-gradient(135deg, #f1d8c9, #fff8f5);
  border-radius: 32rpx;
}

.cover-preview,
.cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.cover-empty {
  color: rgba(45, 37, 32, 0.46);
  font-size: 28rpx;
  letter-spacing: 3rpx;
}

.soft-button {
  margin: 18rpx 0 0;
  padding: 16rpx 24rpx;
  color: var(--color-primary);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  background: #f8eee8;
  border-radius: 999rpx;
}

.hint {
  margin-top: 16rpx;
  color: var(--color-primary);
  font-size: 24rpx;
}

.split-row {
  display: flex;
  gap: 18rpx;
}

.split-field {
  flex: 1;
}

.save-button {
  margin: 34rpx 0 0;
  padding: 24rpx;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.2;
  background: var(--color-primary);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 34rpx rgba(183, 137, 92, 0.25);
}
