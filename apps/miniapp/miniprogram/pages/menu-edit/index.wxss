.edit-page {
  padding-bottom: 48rpx;
  background:
    radial-gradient(circle at 90% 0%, rgba(254, 240, 138, 0.42), transparent 30%),
    var(--color-bg);
}

.intro,
.form-card {
  padding: 34rpx;
}

.form-card {
  margin-top: 28rpx;
}

.eyebrow {
  color: #7f8f66;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.headline {
  margin-top: 14rpx;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.18;
}

.type-row,
.meal-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.type-chip,
.meal-chip {
  margin: 0;
  padding: 15rpx 24rpx;
  color: #526456;
  font-size: 25rpx;
  line-height: 1.2;
  background: #f8faf7;
  border-radius: 999rpx;
}

.type-chip.active,
.meal-chip.active {
  color: #17211b;
  font-weight: 800;
  background: linear-gradient(135deg, #bef264, #fef08a);
}

.type-chip::after,
.meal-chip::after,
.soft-button::after,
.save-button::after {
  border: 0;
}

.field-label {
  margin: 28rpx 0 12rpx;
  color: #526456;
  font-size: 24rpx;
  font-weight: 800;
}

.section-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 800;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  color: var(--color-text);
  font-size: 27rpx;
  background: #f8faf7;
  border-radius: 26rpx;
}

.input {
  height: 84rpx;
}

.textarea {
  min-height: 170rpx;
}

.textarea.tall {
  min-height: 240rpx;
}

.cover-picker {
  overflow: hidden;
  height: 310rpx;
  background: linear-gradient(135deg, rgba(220, 252, 231, 0.9), rgba(254, 249, 195, 0.92));
  border-radius: 32rpx;
}

.cover-preview,
.cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.cover-empty {
  color: rgba(23, 33, 27, 0.48);
  font-size: 28rpx;
  letter-spacing: 3rpx;
}

.soft-button {
  margin: 18rpx 0 0;
  padding: 16rpx 24rpx;
  color: #48604d;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  background: rgba(220, 252, 231, 0.86);
  border-radius: 999rpx;
}

.hint {
  margin-top: 16rpx;
  color: #7f8f66;
  font-size: 24rpx;
}

.split-row {
  display: flex;
  gap: 18rpx;
}

.split-field {
  flex: 1;
}

.save-button {
  margin: 34rpx 0 0;
  padding: 24rpx;
  color: #17211b;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.2;
  background: linear-gradient(135deg, #bef264, #fef08a);
  border-radius: 999rpx;
  box-shadow: 0 18rpx 44rpx rgba(190, 242, 100, 0.26);
}
