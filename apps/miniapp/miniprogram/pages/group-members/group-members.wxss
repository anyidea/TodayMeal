.group-members-page {
  padding-bottom: 120rpx;
}

.group-members-page .topbar {
  position: relative;
  justify-content: flex-start;
  padding-right: 190rpx;
}

.group-members-page .back {
  flex: 0 0 64rpx;
}

.group-members-page .page-title {
  position: absolute;
  left: 50%;
  max-width: 260rpx;
  overflow: hidden;
  color: #2d2520;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  text-overflow: ellipsis;
  transform: translateX(-50%);
  white-space: nowrap;
}

.group-members-page .capsule-space {
  flex: 1;
  min-width: 190rpx;
}

.members-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 32rpx;
  padding: 28rpx;
}

.group-name {
  margin-bottom: 8rpx;
  color: #2d2520;
  font-size: 32rpx;
  font-weight: 800;
}

.member-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #efe7e1;
}

.member-row:last-child {
  border-bottom: 0;
}

.member-avatar-wrap {
  position: relative;
  flex: 0 0 auto;
}

.member-avatar-wrap.removable {
  padding: 4rpx;
  border-radius: 999rpx;
  background: #fff8f5;
  box-shadow: inset 0 0 0 2rpx rgba(183, 137, 92, 0.22);
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f5eae2;
}

.member-avatar.fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #b7895c;
  font-size: 24rpx;
  font-weight: 800;
}

.remove-dot {
  position: absolute;
  right: -4rpx;
  top: -4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #fff;
  border-radius: 50%;
  background: #2d2520;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.member-main {
  display: flex;
  flex-direction: column;
}

.member-name {
  color: #2d2520;
  font-size: 28rpx;
  font-weight: 700;
}

.member-role {
  margin-top: 6rpx;
  color: #8c7f76;
  font-size: 22rpx;
}

.invite-action {
  width: 100%;
  margin-top: 28rpx;
}
