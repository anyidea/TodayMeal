.today-page {
  background:
    radial-gradient(circle at 18% 0%, rgba(183, 137, 92, 0.12), transparent 36%),
    linear-gradient(180deg, #fff8f5 0%, #f5eae2 55%, #fff8f5 100%),
    var(--color-bg);
}

.home-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 10rpx 0 30rpx;
}

.hello {
  color: var(--color-text);
  font-size: 46rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.date {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 26rpx;
}

.add-mini {
  margin: 0;
  padding: 18rpx 28rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.2;
  background: var(--color-primary);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 28rpx rgba(183, 137, 92, 0.26);
}

.hero-card {
  position: relative;
  overflow: hidden;
  display: flex;
  min-height: 372rpx;
  padding: 34rpx;
  background: linear-gradient(135deg, #fff8f5, #ffffff 62%);
}

.hero-copy {
  position: relative;
  z-index: 2;
  flex: 1;
  padding-right: 18rpx;
}

.hero-kicker,
.section-label {
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 18rpx;
  color: var(--color-text);
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.12;
}

.hero-desc {
  margin-top: 16rpx;
  color: var(--color-muted);
  font-size: 26rpx;
  line-height: 1.55;
}

.hero-image {
  flex: 0 0 228rpx;
  width: 228rpx;
  height: 274rpx;
  align-self: center;
  border-radius: 28rpx;
}

.empty-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(45, 37, 32, 0.42);
  font-size: 24rpx;
  letter-spacing: 3rpx;
  background: linear-gradient(135deg, #f1d8c9, #fff8f5);
}

.hero-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 30rpx;
}

.primary-action {
  margin: 0;
  padding: 18rpx 28rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.2;
  background: var(--color-primary);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 30rpx rgba(183, 137, 92, 0.22);
}

.primary-action.drawing {
  transform: scale(0.98);
  opacity: 0.82;
}

.ghost-action {
  margin: 0;
  padding: 18rpx 28rpx;
  color: var(--color-primary);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.2;
  background: #f8eee8;
  border-radius: 999rpx;
}

.empty {
  padding: 34rpx;
}

.quick-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.quick-card {
  flex: 1;
  min-height: 152rpx;
  padding: 28rpx;
  background: #ffffff;
}

.quick-card.accent {
  background: #f1d8c9;
}

.quick-title,
.empty-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.quick-desc,
.empty-text {
  margin-top: 12rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.55;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 42rpx 4rpx 22rpx;
}

.section-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.link {
  color: var(--color-primary);
  font-size: 25rpx;
  font-weight: 800;
}

.inspiration-scroll {
  width: 100%;
  white-space: nowrap;
}

.inspiration-row {
  display: flex;
  gap: 20rpx;
  padding: 2rpx 4rpx 8rpx;
}

.inspiration-card {
  flex: 0 0 240rpx;
  width: 240rpx;
  padding: 16rpx;
  background: #ffffff;
  border: 1rpx solid var(--color-line);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-light);
}

.inspiration-image {
  width: 100%;
  height: 168rpx;
  border-radius: 22rpx;
}

.inspiration-title {
  margin-top: 16rpx;
  color: var(--color-text);
  font-size: 28rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.inspiration-subtitle {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.takeout-head {
  margin-top: 36rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 28rpx;
}
