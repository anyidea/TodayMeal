<view class="page list-page">
  <view class="topbar">
    <text class="page-title">我的菜谱</text>
    <view class="tools">
      <view class="tool-btn">
        <t-icon class="tm-icon" name="search" size="36rpx" color="#2D2520" />
      </view>
      <view class="tool-btn" bindtap="goAdd">
        <t-icon class="tm-icon" name="add" size="36rpx" color="#2D2520" />
      </view>
    </view>
  </view>

  <scroll-view class="tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tab-row">
      <block wx:for="{{tabs}}" wx:key="*this">
        <view class="tab {{activeTab === index ? 'active' : ''}}" data-index="{{index}}" bindtap="chooseTab">{{item}}</view>
      </block>
    </view>
  </scroll-view>

  <view class="recipe-list">
    <block wx:for="{{recipes}}" wx:key="name">
      <view class="recipe-item soft-card">
        <image wx:if="{{item.image}}" class="recipe-img" src="{{item.image}}" mode="aspectFill"></image>
        <view wx:else class="recipe-img recipe-img-placeholder">
          <t-icon class="tm-icon" name="rice-ball" size="38rpx" color="#B7895C" />
        </view>
        <view class="recipe-info">
          <view class="recipe-top">
            <text class="recipe-name">{{item.name}}</text>
            <view
              class="more-btn"
              data-id="{{item.id}}"
              data-favorite="{{item.isFavorite ? '1' : '0'}}"
              catchtap="showRecipeMenu"
            >
              <t-icon class="tm-icon" name="more" size="32rpx" color="#C5BEB8" />
            </view>
          </view>
          <text class="recipe-meta">{{item.meta}}</text>
          <view wx:if="{{item.time || item.isFavorite}}" class="recipe-bottom">
            <view wx:if="{{item.time}}" class="meta-tag">
              <t-icon class="tm-icon icon-inline" name="time" size="24rpx" color="#B7895C" />
              <text>{{item.time}}</text>
            </view>
            <view wx:if="{{item.isFavorite}}" class="meta-tag favorite-tag">
              <t-icon class="tm-icon icon-inline" name="heart" size="24rpx" color="#FF6B6B" />
              <text>已收藏</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="nav-bar">
    <view class="nav-item" bindtap="goHome">
      <t-icon class="tm-icon" name="home" size="36rpx" color="#8C7F76" />
      <text>首页</text>
    </view>
    <view class="nav-item active">
      <t-icon class="tm-icon" name="book-open" size="36rpx" color="#B7895C" />
      <text>菜谱</text>
    </view>
    <view class="nav-item nav-random" bindtap="goRandom">
      <t-icon class="tm-icon" name="refresh" size="44rpx" color="#FFFFFF" />
      <text>随机</text>
    </view>
    <view class="nav-item" bindtap="goFavorites">
      <t-icon class="tm-icon" name="heart" size="36rpx" color="#8C7F76" />
      <text>收藏</text>
    </view>
    <view class="nav-item" bindtap="goProfile">
      <t-icon class="tm-icon" name="user" size="36rpx" color="#8C7F76" />
      <text>我的</text>
    </view>
  </view>
</view>
