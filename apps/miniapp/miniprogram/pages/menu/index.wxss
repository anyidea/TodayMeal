.menu-page {
  background:
    linear-gradient(180deg, #fff8f5 0%, #f5eae2 430rpx, #fff8f5 100%),
    var(--color-bg);
}

.top-card {
  padding: 18rpx 4rpx 8rpx;
}

.eyebrow {
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.headline {
  margin-top: 16rpx;
  color: var(--color-text);
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1.18;
}

.subline {
  margin-top: 12rpx;
  color: var(--color-muted);
  font-size: 26rpx;
  line-height: 1.5;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
}

.search {
  flex: 1;
  height: 82rpx;
  padding: 0 28rpx;
  color: var(--color-text);
  font-size: 27rpx;
  background: #ffffff;
  border: 1rpx solid var(--color-line);
  border-radius: 26rpx;
  box-shadow: var(--shadow-light);
}

.filter-btn,
.empty-action {
  margin: 0;
  padding: 20rpx 28rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.2;
  background: var(--color-primary);
  border-radius: 999rpx;
}

.filter-panel {
  margin-top: 22rpx;
  padding: 24rpx 26rpx 28rpx;
}

.active-tag-row {
  display: flex;
  justify-content: space-between;
  margin-top: 22rpx;
  color: var(--color-muted);
  font-size: 24rpx;
}

.clear {
  color: var(--color-primary);
  font-weight: 800;
}

.list-head {
  display: flex;
  justify-content: space-between;
  margin: 36rpx 4rpx 20rpx;
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 800;
}

.count {
  color: var(--color-muted);
  font-size: 24rpx;
  font-weight: 500;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: 28rpx;
}

.empty {
  padding: 44rpx;
  text-align: center;
}

.empty-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.empty-text {
  margin-top: 16rpx;
  color: var(--color-muted);
  font-size: 25rpx;
  line-height: 1.55;
}

.empty-action {
  display: inline-flex;
  margin-top: 28rpx;
}

.float-add {
  position: fixed;
  right: 34rpx;
  bottom: calc(164rpx + env(safe-area-inset-bottom));
  z-index: 20;
  margin: 0;
  padding: 22rpx 34rpx;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.2;
  background: var(--color-primary);
  border-radius: 999rpx;
  box-shadow: 0 12rpx 34rpx rgba(183, 137, 92, 0.28);
}
