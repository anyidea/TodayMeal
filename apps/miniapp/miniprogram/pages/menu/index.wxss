.menu-page {
  background:
    linear-gradient(180deg, rgba(220, 252, 231, 0.56), transparent 360rpx),
    var(--color-bg);
}

.top-card {
  padding: 34rpx;
  background: rgba(255, 255, 255, 0.9);
}

.eyebrow {
  color: #7f8f66;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.headline {
  margin-top: 16rpx;
  color: var(--color-text);
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.18;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 30rpx;
}

.search {
  flex: 1;
  height: 82rpx;
  padding: 0 28rpx;
  color: var(--color-text);
  font-size: 27rpx;
  background: #f8faf7;
  border-radius: 26rpx;
}

.add-btn,
.empty-action {
  margin: 0;
  padding: 20rpx 28rpx;
  color: #17211b;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.2;
  background: linear-gradient(135deg, #bef264, #fef08a);
  border-radius: 999rpx;
}

.add-btn::after,
.empty-action::after {
  border: 0;
}

.list-head {
  display: flex;
  justify-content: space-between;
  margin: 38rpx 4rpx 20rpx;
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 800;
}

.count {
  color: var(--color-muted);
  font-size: 24rpx;
  font-weight: 500;
}

.grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 28rpx;
}

.empty {
  padding: 44rpx;
  text-align: center;
}

.empty-title {
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.empty-text {
  margin-top: 16rpx;
  color: var(--color-muted);
  font-size: 25rpx;
  line-height: 1.55;
}

.empty-action {
  display: inline-flex;
  margin-top: 28rpx;
}
