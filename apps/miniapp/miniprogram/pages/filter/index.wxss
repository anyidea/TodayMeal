.filter-page {
  padding-bottom: 180rpx;
  background:
    linear-gradient(180deg, #fff8f5 0%, #f5eae2 460rpx, #fff8f5 100%),
    var(--color-bg);
}

.head {
  padding: 12rpx 4rpx 24rpx;
}

.eyebrow {
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.headline {
  margin-top: 14rpx;
  color: var(--color-text);
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.16;
}

.search {
  height: 86rpx;
  margin-top: 26rpx;
  padding: 0 28rpx;
  color: var(--color-text);
  font-size: 27rpx;
  background: #ffffff;
  border: 1rpx solid var(--color-line);
  border-radius: 28rpx;
  box-shadow: var(--shadow-light);
}

.filter-card {
  margin-top: 20rpx;
  padding: 30rpx;
}

.group-title {
  color: var(--color-text);
  font-size: 31rpx;
  font-weight: 900;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.chip {
  margin: 0;
  padding: 16rpx 24rpx;
  color: var(--color-muted);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  background: #fff8f5;
  border: 1rpx solid var(--color-line);
  border-radius: 999rpx;
}

.chip.active {
  color: #ffffff;
  background: var(--color-primary);
  border-color: var(--color-primary);
  box-shadow: 0 10rpx 26rpx rgba(183, 137, 92, 0.22);
}

.bottom-actions {
  position: fixed;
  right: 32rpx;
  bottom: 34rpx;
  left: 32rpx;
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid var(--color-line);
  border-radius: 34rpx;
  box-shadow: var(--shadow-medium);
}

.reset,
.apply {
  flex: 1;
  margin: 0;
  padding: 22rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
  border-radius: 999rpx;
}

.reset {
  color: var(--color-primary);
  background: #f8eee8;
}

.apply {
  color: #ffffff;
  background: var(--color-primary);
}
