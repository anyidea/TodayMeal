<view class="page filter-page">
  <view class="head">
    <view class="eyebrow">FILTER</view>
    <view class="headline">按今天的感觉筛一筛</view>
    <input class="search" placeholder="也可以直接搜菜名、餐厅、备注" value="{{q}}" bindinput="handleInput" />
  </view>

  <view class="filter-card card">
    <view class="group-title">类型</view>
    <view class="chip-grid">
      <button wx:for="{{typeOptions}}" wx:key="value" class="chip {{activeType === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="chooseType">{{item.label}}</button>
    </view>
  </view>

  <view class="filter-card card">
    <view class="group-title">场景</view>
    <view class="chip-grid">
      <button wx:for="{{sceneOptions}}" wx:key="value" class="chip {{activeMealPeriod === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="chooseMealPeriod">{{item.label}}</button>
    </view>
  </view>

  <view class="filter-card card">
    <view class="group-title">口味</view>
    <view class="chip-grid">
      <button wx:for="{{flavorOptions}}" wx:key="value" class="chip {{activeTag === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="chooseTag">{{item.label}}</button>
    </view>
  </view>

  <view class="filter-card card">
    <view class="group-title">烹饪方式</view>
    <view class="chip-grid">
      <button wx:for="{{cookingOptions}}" wx:key="value" class="chip {{activeTag === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="chooseTag">{{item.label}}</button>
    </view>
  </view>

  <view class="filter-card card">
    <view class="group-title">食材</view>
    <view class="chip-grid">
      <button wx:for="{{ingredientOptions}}" wx:key="value" class="chip {{activeTag === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="chooseTag">{{item.label}}</button>
    </view>
  </view>

  <view class="bottom-actions">
    <button class="reset" bindtap="reset">重置</button>
    <button class="apply" bindtap="apply">查看结果</button>
  </view>
</view>
