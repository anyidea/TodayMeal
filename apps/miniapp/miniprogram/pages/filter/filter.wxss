.filter-page {
  padding-bottom: 176rpx;
}

.filter-page .topbar {
  position: relative;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
}

.back {
  position: absolute;
  left: 0;
  color: #2d2520;
}

.icon-button {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  min-width: 64rpx;
  height: 64rpx;
  padding: 0;
}

.icon-button .tm-icon {
  width: 34rpx;
  height: 34rpx;
}

.reset {
  flex: 0 0 auto;
  width: auto;
  min-width: 0;
  padding: 0 4rpx 0 18rpx;
  color: #8c7f76;
  font-size: 24rpx;
  line-height: 1;
}

.filter-page .page-title {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  white-space: nowrap;
}

.filter-section {
  margin-top: 36rpx;
}

.filter-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.filter-title {
  display: block;
  color: #2d2520;
  font-size: 28rpx;
  font-weight: 600;
}

.chip-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx 12rpx;
}

.chip-grid .chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 56rpx;
  padding: 0 6rpx;
  border-radius: 28rpx;
  background: #fff;
  color: #8c7f76;
  font-size: 24rpx;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
  box-shadow: 0 2rpx 12rpx rgba(45, 37, 32, 0.03);
}

.chip-grid .chip-stack {
  flex-direction: column;
  gap: 6rpx;
  height: 110rpx;
  padding: 14rpx 4rpx;
  border-radius: 28rpx;
}

.chip-grid .chip-stack .chip-icon {
  flex: 0 0 auto;
}

.chip-grid .chip-stack .chip-label {
  font-size: 22rpx;
  line-height: 1;
}

.chip-grid .chip.active {
  background: #f5eae2;
  color: #b7895c;
  font-weight: 600;
}

.submit {
  position: fixed;
  right: 32rpx;
  bottom: 52rpx;
  left: 32rpx;
  box-shadow: 0 14rpx 28rpx rgba(183, 137, 92, 0.25);
}
