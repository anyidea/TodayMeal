.tab-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 99;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(245, 234, 226, 0), rgba(245, 234, 226, 0.96) 36%);
}

.tab-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 108rpx;
  padding: 8rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid #efe7e1;
  border-radius: 34rpx;
  box-shadow: 0 8rpx 34rpx rgba(45, 37, 32, 0.1);
}

.tab-item {
  position: relative;
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  border-radius: 28rpx;
}

.tab-label {
  margin-top: 44rpx;
  color: #8c7f76;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  line-height: 1;
}

.tab-indicator {
  position: absolute;
  top: 18rpx;
  width: 30rpx;
  height: 6rpx;
  background: transparent;
  border-radius: 999rpx;
}

.tab-mark {
  position: absolute;
  top: 22rpx;
  width: 30rpx;
  height: 30rpx;
  border: 3rpx solid #8c7f76;
  border-radius: 10rpx;
  opacity: 0.72;
}

.tab-item:nth-child(3) {
  flex: 1.25;
}

.tab-item:nth-child(3) .tab-mark {
  top: 10rpx;
  width: 76rpx;
  height: 76rpx;
  background: var(--color-primary);
  border: 0;
  border-radius: 50%;
  box-shadow: 0 10rpx 24rpx rgba(183, 137, 92, 0.28);
}

.tab-item:nth-child(3) .tab-mark::after {
  content: "";
}

.tab-item:nth-child(3) .tab-label {
  margin-top: 0;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  z-index: 2;
}

.tab-item.active {
  background: #f5eae2;
}

.tab-item.active .tab-label {
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 800;
}

.tab-item.active .tab-indicator {
  background: var(--color-primary);
}

.tab-item.active .tab-mark {
  border-color: var(--color-primary);
  opacity: 1;
}

.tab-item:nth-child(3).active {
  background: transparent;
}

.tab-item:nth-child(3).active .tab-label {
  color: #ffffff;
}

.tab-item:nth-child(3).active .tab-indicator {
  background: transparent;
}
