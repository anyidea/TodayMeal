page {
  --color-primary: #b7895c;
  --color-primary-dark: #9f704a;
  --color-bg: #f5eae2;
  --color-bg-soft: #fff8f5;
  --color-card: #ffffff;
  --color-text: #2d2520;
  --color-muted: #8c7f76;
  --color-line: #efe7e1;
  --color-success: #5fb878;
  --color-danger: #ff688a;
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --shadow-light: 0 4rpx 24rpx rgba(45, 37, 32, 0.06);
  --shadow-medium: 0 8rpx 34rpx rgba(45, 37, 32, 0.08);
  --shadow-strong: 0 12rpx 48rpx rgba(45, 37, 32, 0.12);
  --shadow-card: var(--shadow-light);
  background: var(--color-bg);
  color: var(--color-text);
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}
