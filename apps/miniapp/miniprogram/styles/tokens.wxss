page {
  --color-bg: #f8faf7;
  --color-card: #ffffff;
  --color-text: #17211b;
  --color-muted: #7a8a7d;
  --color-accent: #bef264;
  --color-accent-soft: #dcfce7;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --shadow-card: 0 18rpx 60rpx rgba(15, 23, 42, 0.08);
  background: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}
